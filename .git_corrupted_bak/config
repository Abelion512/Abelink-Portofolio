[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = https://github.com/Abelion512/Abelink-Portofolio.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "feature/nextjs-setup"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/feature/nextjs-setup
