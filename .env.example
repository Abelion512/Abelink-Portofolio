# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── AI (OpenAI-compatible — works with OpenRouter, OpenAI, Groq, Gemini via API) ─
# Default: OpenRouter (https://openrouter.ai/api/v1)
# Common providers:
#   OpenRouter:   https://openrouter.ai/api/v1
#   OpenAI:       https://api.openai.com/v1
#   Groq:         https://api.groq.com/openai/v1
#   Gemini:       https://generativelanguage.googleapis.com/v1beta/openai/
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=your-api-key
# Common model values:
#   OpenRouter: openai/gpt-4o-mini, anthropic/claude-3-haiku, google/gemini-2.0-flash
#   OpenAI:     gpt-4o-mini, gpt-4o
#   Groq:       gemma2-9b-it, llama-3.3-70b-versatile
AI_MODEL=openai/gpt-4o-mini

# ── Contact ────────────────────────────────────────────────────────────────────
# Email displayed in contact page
NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com

# ── Social Links ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/Abelion512
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/ihsanovid
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/in/ihsanuddin-abelion

# ── Site URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://abelion.vercel.app

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Music (Last.fm) ───────────────────────────────────────────────────────────
# Get from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_USERNAME=your-username

# ── Telegram (Edge Functions) ──────────────────────────────────────────────────
# Get from: @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id